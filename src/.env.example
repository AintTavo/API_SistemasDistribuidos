# ── PaTavo monolito — variables de entorno ────────────────────────
# Copia este archivo a .env y ajusta los valores en producción.

# Puerto público donde Nginx expone el front + la API.
WEB_PORT=8080

# Credenciales de PostgreSQL.
POSTGRES_USER=patavo
POSTGRES_PASSWORD=patavo
POSTGRES_DB=patavo

# Secreto JWT del monolito (¡cámbialo!).
JWT_SECRET=patavo-monolith-secret
