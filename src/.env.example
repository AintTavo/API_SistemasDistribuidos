# ── El mapa del aventurero monolito — variables de entorno ────────────────────────
# Copia este archivo a .env y ajusta los valores en producción.

# Puerto público donde Nginx expone el front + la API.
WEB_PORT=8080

# Credenciales de PostgreSQL.
POSTGRES_USER=mapa-aventurero
POSTGRES_PASSWORD=mapa-aventurero
POSTGRES_DB=mapa-aventurero

# Secreto JWT del monolito (¡cámbialo!).
JWT_SECRET=mapa-aventurero-monolith-secret
